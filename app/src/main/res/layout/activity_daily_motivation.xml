<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8FF6E0"
    tools:context=".DailyMotivation">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily Motivation"
        android:textSize="30sp"
        android:textColor="#182b7c"
        android:textAlignment="center"
        android:layout_margin="20dp"
        android:fontFamily="sans-serif-black"
        />

    <ImageView
        android:layout_width="331dp"
        android:layout_height="353dp"
        android:layout_margin="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/motivation" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:textColor="#08596b"
        android:textSize="20dp"
        android:fontFamily="casual"
        android:text="Embrace discipline as an opportunity to create lasting value, as small, persistent actions generate significant results. \n Focus on the present to build your future, viewing challenges as chances to strengthen your resolve and align with reality. \n Your potential is unlocked by persevering, staying consistent, and choosing self-care"
        />




</LinearLayout>